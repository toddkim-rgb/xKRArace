# dependencies / build output (web/ has its own too; these are a safety net)
node_modules/
.next/
out/

# env & secrets (keep the template)
.env
.env.*
!.env.example

# vercel
.vercel/
.vercel

# python
__pycache__/
*.pyc
*.pyo

# debug text dumps from the parser
data/*.txt

# per-meeting upsert SQL generated by ingest.py --sql (regenerable artifact)
supabase/ingest_*.sql

# claude local settings (launch.json is intentionally shared)
.claude/settings.local.json

# os cruft
.DS_Store
Thumbs.db
